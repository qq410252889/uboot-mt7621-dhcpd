# 启用MIPS架构
CONFIG_MIPS=y
# TPL阶段最大镜像大小 128KB (修复空间不足)
CONFIG_TPL_MAX_SIZE=131072
# SPL阶段支持串口输出
CONFIG_SPL_SERIAL_SUPPORT=y
# TPL阶段启用通用库支持
CONFIG_TPL_LIBGENERIC_SUPPORT=y
# 环境变量分区大小64KB
CONFIG_ENV_SIZE=0x10000
# SPL阶段早期堆内存大小1MB
CONFIG_SPL_SYS_MALLOC_F_LEN=0x100000
# 调试串口由板级初始化
CONFIG_DEBUG_UART_BOARD_INIT=y
# 调试串口寄存器基地址
CONFIG_DEBUG_UART_BASE=0xbe000c00
# 调试串口时钟50MHz
CONFIG_DEBUG_UART_CLOCK=50000000
# 平台为MT7621
CONFIG_MACH_MT7621=y
# 使用MT7621 NOR Flash模板
CONFIG_BOARD_MT7621_NOR_TEMPLATE=y
# 使用传统DRAM初始化固件
CONFIG_MT7621_LEGACY_DRAMC_BIN=y
# 传统模式配置DDR3 1024M内存
CONFIG_MT7621_DRAM_DDR3_1024M_LEGACY=y
# 关闭DRAMC调试日志
# CONFIG_MT7621_DRAMC_DEBUG_LEGACY is not set
# NOR Flash内核默认偏移地址0x180000
CONFIG_DEFAULT_NOR_KERNEL_OFFSET=0x180000
# MTK自动启动延时1秒
CONFIG_MTKAUTOBOOT_DELAY=1
# 使用ROM异常向量表
CONFIG_ROM_EXCEPTION_VECTORS=y
# MIPS启动支持设备树FDT
CONFIG_MIPS_BOOT_FDT=y
# 启用调试串口
CONFIG_DEBUG_UART=y
# 关闭版本号自动生成
# CONFIG_LOCALVERSION_AUTO is not set
# 内存物理块数量为1
CONFIG_NR_DRAM_BANKS=1
# 关闭专家模式
# CONFIG_EXPERT is not set
# 启用FIT镜像格式支持
CONFIG_FIT=y
# 关闭设备树内存自动修正
# CONFIG_ARCH_FIXUP_FDT_MEMORY is not set
# 从SPI Flash启动
CONFIG_SPI_BOOT=y
# 开机无延时直接启动
CONFIG_BOOTDELAY=0
# 使用自定义启动命令
CONFIG_USE_BOOTCOMMAND=y
# 默认启动命令：mtk自动引导
CONFIG_BOOTCOMMAND="mtkautoboot"
# 控制台静默输出（精简日志）
CONFIG_SYS_CONSOLE_INFO_QUIET=y
# 开机显示CPU信息
CONFIG_DISPLAY_CPUINFO=y
# 启用最后阶段初始化钩子
CONFIG_LAST_STAGE_INIT=y
# SPL加载的镜像：LZMA压缩的U-Boot
CONFIG_SPL_PAYLOAD="u-boot-lzma.img"
# SPL支持YMODEM串口传输
CONFIG_SPL_YMODEM_SUPPORT=y
# 启用TPL最小化启动加载器
CONFIG_TPL=y
# TPL需要独立代码基地址
CONFIG_TPL_NEEDS_SEPARATE_TEXT_BASE=y
# 启用启动菜单命令
CONFIG_CMD_BOOTMENU=y
# 关闭ELF格式启动命令
# CONFIG_CMD_ELF is not set
# 关闭XIMG镜像命令
# CONFIG_CMD_XIMG is not set
# 关闭原生FLASH命令
# CONFIG_CMD_FLASH is not set
# 启用GPIO操作命令
CONFIG_CMD_GPIO=y
# 启用SPI Flash读写命令
CONFIG_CMD_SF=y
# 启用DHCP客户端命令
CONFIG_CMD_DHCP=y
# 关闭NFS网络文件系统
# CONFIG_CMD_NFS is not set
# 启用PING网络测试命令
CONFIG_CMD_PING=y
# 启用MTD分区操作命令
CONFIG_CMD_MTDPARTS=y
# 默认MTD设备名称
CONFIG_MTDIDS_DEFAULT="nor0=raspi"
# 🔥 修复分区：u-boot 从 192k 扩大到 256k，完美容纳 205KB
CONFIG_MTDPARTS_DEFAULT="mtdparts=raspi:256k(u-boot),64k(u-boot-env),64k(factory),64k(factory),64k(crash),64k(cfg_bak),1m(overlay),-(firmware)"
# 关闭简易分区，使用MTD分区
# CONFIG_PARTITIONS is not set
# 启用设备树控制
CONFIG_OF_CONTROL=y
# 设备树内嵌到U-Boot
CONFIG_OF_EMBED=y
# 默认设备树文件
CONFIG_DEFAULT_DEVICE_TREE="mt7621_nor_template"
# 随机生成以太网MAC地址
CONFIG_NET_RANDOM_ETHADDR=y
# 关闭设备模型警告日志
# CONFIG_DM_WARN is not set
# 关闭设备树地址翻译
# CONFIG_OF_TRANSLATE is not set
# 启用设备模型GPIO
CONFIG_DM_GPIO=y
# MT7621专用GPIO驱动
CONFIG_MT7621_GPIO=y
# 启用MTD存储子系统
CONFIG_MTD=y
# 启用MTD分区支持
CONFIG_MTD_PARTITIONS=y
# 设备模型SPI Flash驱动
CONFIG_DM_SPI_FLASH=y
# 启用SPI Flash核心支持
CONFIG_SPI_FLASH=y
# 启用SPI Flash块地址寄存器
CONFIG_SPI_FLASH_BAR=y
# 兼容各品牌SPI Flash芯片
CONFIG_SPI_FLASH_EON=y
CONFIG_SPI_FLASH_GIGADEVICE=y
CONFIG_SPI_FLASH_ISSI=y
CONFIG_SPI_FLASH_MACRONIX=y
CONFIG_SPI_FLASH_SPANSION=y
CONFIG_SPI_FLASH_STMICRO=y
CONFIG_SPI_FLASH_SST=y
CONFIG_SPI_FLASH_WINBOND=y
CONFIG_SPI_FLASH_XMC=y
# 不使用4K扇区模式
# CONFIG_SPI_FLASH_USE_4K_SECTORS is not set
# SPI Flash绑定MTD子系统
CONFIG_SPI_FLASH_MTD=y
# 启用固定PHY模式
CONFIG_PHY_FIXED=y
# 设备模型以太网驱动
CONFIG_DM_ETH=y
# MT7621以太网MAC驱动
CONFIG_MT7621_ETH=y
# 启用引脚控制
CONFIG_PINCTRL=y
# 启用引脚电气配置
CONFIG_PINCONF=y
# MT7621引脚控制器驱动
CONFIG_PINCTRL_MT7621=y
# 设备模型复位控制器
CONFIG_DM_RESET=y
# MT7621复位驱动
CONFIG_MT7621_RESET=y
# 设备模型串口驱动
CONFIG_DM_SERIAL=y
# TPL阶段不启用DM串口
# CONFIG_TPL_DM_SERIAL is not set
# 联发科调试串口适配
CONFIG_DEBUG_UART_MTK=y
# 调试串口地址偏移移位
CONFIG_DEBUG_UART_SHIFT=2
# 联发科串口通用驱动
CONFIG_MTK_SERIAL=y
# 启用SPI总线
CONFIG_SPI=y
# 设备模型SPI驱动
CONFIG_DM_SPI=y
# MT7621 SPI控制器驱动
CONFIG_MT7621_SPI=y
# 启用LZMA解压缩
CONFIG_LZMA=y
# SPL阶段支持LZMA解压
CONFIG_SPL_LZMA=y
# 启用Web网页救援模式
CONFIG_WEBUI_FAILSAFE=y
# 启动失败自动进入Web救援
CONFIG_WEBUI_FAILSAFE_ON_AUTOBOOT_FAIL=y
# 支持按键触发进入救援模式
CONFIG_FAILSAFE_ON_BUTTON=y
# Reset复位按键使用GPIO 18
CONFIG_MT7621_BUTTON_RESET=18
# 启用状态LED1
CONFIG_MT7621_LED_STATUS1_ENABLE=y
# 状态LED1使用GPIO 8
CONFIG_MT7621_LED_STATUS1=8
# Web救援显示的设备型号：小米路由器4A/3Gv2
CONFIG_WEBUI_FAILSAFE_BOARD_MODEL="Xiaomi_Mi_Router_4a/3g-v2"
# Web救援显示的设备名称
CONFIG_WEBUI_FAILSAFE_BOARD_NAME="Xiaomi_Mi_Router_4a/3g-v2"
